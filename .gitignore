# Ignore all files by default
*

# But allow git files
!.gitignore
!.github/
!.gitkeep

# Allow Arduino folders
!motor_compass_controller/
!motor_compass_controller/**
!motor_imu_controller/
!motor_imu_controller/**

# Allow Bridge folder
!pi_tcp_bridge/
!pi_tcp_bridge/**

# Allow documentation
!README.md
!QUICKSTART.md
!PROTOCOL_DOCUMENTATION.md
!DELIVERY_SUMMARY.md
